{
  "comment": "Input for scripts/patch-manifest.py. Entries are stripped-and-readded by their Custom/ paths; 'matches': 'all-platforms' is replaced with the computed union of upstream + custom host patterns. Run the patcher after any upstream resync.",
  "bridge": {
    "matches": "all-platforms",
    "run_at": "document_start",
    "js": [
      "Custom/bridge.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.threads.com/*"
      ],
      "run_at": "document_start",
      "css": [
        "Custom/threads.css"
      ],
      "js": [
        "Custom/lib.js",
        "Custom/threads.js"
      ]
    },
    {
      "matches": [
        "*://news.ycombinator.com/*"
      ],
      "run_at": "document_start",
      "css": [
        "Custom/hackernews.css"
      ],
      "js": [
        "Custom/lib.js",
        "Custom/hackernews.js"
      ]
    },
    {
      "matches": [
        "*://github.com/*"
      ],
      "run_at": "document_start",
      "css": [
        "Custom/github.css"
      ],
      "js": [
        "Custom/lib.js",
        "Custom/github.js"
      ]
    },
    {
      "matches": "all-platforms",
      "run_at": "document_idle",
      "css": [
        "Custom/quote-widget.css"
      ],
      "js": [
        "Custom/quotes.js",
        "Custom/quote-widget.js"
      ]
    }
  ]
}
